# =========================================================================
# ELRAWDA Family Console - Environment Variables Template
# =========================================================================
# Copy this file to '.env' and fill in your local and production credentials.
# Make sure '.env' is never checked into your repository.

# -------------------------------------------------------------------------
# App Settings
# -------------------------------------------------------------------------
NODE_ENV=development
PORT=5000
APP_NAME=ELRAWDA
APP_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Email Provider Settings
# -------------------------------------------------------------------------
# Supported values: resend, smtp, sendgrid, mailgun, debug
# Defaults to:
# - 'debug' in development (NODE_ENV=development) if empty
# - 'resend' in production (NODE_ENV=production) if empty
EMAIL_PROVIDER=resend

# The sender identity (Must be a domain verified in Resend when in production)
# Example: ELRAWDA <noreply@yourdomain.com>
EMAIL_FROM=

# -------------------------------------------------------------------------
# Resend Provider API Configuration
# -------------------------------------------------------------------------
# Required if EMAIL_PROVIDER=resend or in production (since Resend is default)
RESEND_API_KEY=

# -------------------------------------------------------------------------
# SMTP Legacy/Fallback Configuration
# -------------------------------------------------------------------------
# Required if EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# -------------------------------------------------------------------------
# Backend Mode Selector: 'sqlite' or 'supabase'
# -------------------------------------------------------------------------
VITE_BACKEND_PROVIDER=sqlite

# -------------------------------------------------------------------------
# Supabase Configuration Settings
# -------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

